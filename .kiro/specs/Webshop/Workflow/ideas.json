{
  "order_workflow": {
    "states": {
      "order_received": {
        "description": "Klant heeft bestelling geplaatst, betaling nog niet bevestigd.",
        "triggers": ["payment_webhook", "manual_payment_check"],
        "actions": [
          "send_order_confirmation_email",
          "reserve_stock_temporarily"
        ],
        "next": {
          "payment_success": "paid",
          "payment_failed": "payment_failed",
          "payment_pending": "payment_pending"
        }
      },

      "payment_pending": {
        "description": "Betaling in afwachting (bijv. bankoverschrijving, Klarna).",
        "triggers": ["payment_webhook"],
        "actions": ["send_payment_pending_email"],
        "next": {
          "payment_success": "paid",
          "payment_failed": "payment_failed"
        }
      },

      "payment_failed": {
        "description": "Betaling mislukt of verlopen.",
        "actions": [
          "send_payment_failed_email",
          "release_stock"
        ],
        "next": null
      },

      "paid": {
        "description": "Betaling bevestigd.",
        "actions": [
          "reserve_stock",
          "generate_picklist",
          "notify_warehouse"
        ],
        "next": {
          "picked": "picked"
        }
      },

      "picked": {
        "description": "Producten zijn gepickt in het magazijn.",
        "actions": [
          "quality_check",
          "prepare_packaging"
        ],
        "next": {
          "packed": "packed"
        }
      },

      "packed": {
        "description": "Order is verpakt en klaar voor verzending.",
        "actions": [
          "print_shipping_label",
          "attach_packing_slip"
        ],
        "next": {
          "shipped": "shipped"
        }
      },

      "shipped": {
        "description": "Pakket is overgedragen aan vervoerder.",
        "actions": [
          "send_tracking_email",
          "update_carrier_status"
        ],
        "next": {
          "delivered": "delivered"
        }
      },

      "delivered": {
        "description": "Pakket is bezorgd bij klant.",
        "actions": [
          "send_delivery_confirmation",
          "schedule_review_request"
        ],
        "next": {
          "return_requested": "return_requested"
        }
      },

      "return_requested": {
        "description": "Klant heeft een retour aangemeld.",
        "actions": [
          "generate_rma_code",
          "send_return_instructions"
        ],
        "next": {
          "return_received": "return_received"
        }
      },

      "return_received": {
        "description": "Retourpakket ontvangen in magazijn.",
        "actions": [
          "inspect_return",
          "update_stock",
          "process_refund"
        ],
        "next": {
          "completed": "completed"
        }
      },

      "completed": {
        "description": "Order volledig afgerond.",
        "actions": [
          "archive_order",
          "close_ticket_if_open"
        ],
        "next": null
      }
    }
  }
}