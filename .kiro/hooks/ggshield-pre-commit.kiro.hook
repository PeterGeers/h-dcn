{
  "enabled": false,
  "name": "GitGuardian Secret Scan",
  "description": "Runs ggshield secret scan before any code changes are committed to detect leaked secrets",
  "version": "1",
  "when": {
    "type": "preToolUse",
    "toolTypes": [
      "write"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "ggshield secret scan pre-commit",
    "timeout": 30
  }
}