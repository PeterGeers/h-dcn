# H-DCN Portal Secrets
# Copy this file to .secrets and fill in your actual values
# NEVER commit .secrets to version control!
#
# Shared config (pool IDs, region, API URL) is loaded from frontend/.env
# This file only contains actual secrets that can't go in .env

# Google OAuth Configuration
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AWS Cognito Client Secret (not needed by frontend, only backend scripts)
COGNITO_CLIENT_SECRET=your-cognito-client-secret

# CloudFront Distribution ID
CLOUDFRONT_DISTRIBUTION_ID=your-cloudfront-distribution-id
